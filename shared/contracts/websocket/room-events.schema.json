{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RoomRealtimeEvent",
  "type": "object",
  "required": ["type", "payload", "occurredAt"],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "player.joined",
        "player.left",
        "question.claimed",
        "question.claim_rejected",
        "ping",
        "pong"
      ]
    },
    "payload": {
      "type": "object"
    },
    "occurredAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
