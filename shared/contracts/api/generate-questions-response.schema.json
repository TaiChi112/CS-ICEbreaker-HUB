{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GenerateQuestionsResponse",
  "type": "object",
  "required": ["room_id", "room_code", "round_id", "topic", "question_count", "questions"],
  "properties": {
    "room_id": { "type": "string", "format": "uuid" },
    "room_code": { "type": "string" },
    "round_id": { "type": "string", "format": "uuid" },
    "topic": { "type": "string" },
    "question_count": { "type": "integer", "minimum": 0 },
    "questions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["question_id", "round_id", "prompt"],
        "properties": {
          "question_id": { "type": "string", "format": "uuid" },
          "round_id": { "type": "string", "format": "uuid" },
          "prompt": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
