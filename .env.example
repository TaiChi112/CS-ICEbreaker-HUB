# Application
APP_NAME=CS-Icebreaker Hub
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_URL=http://localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cs_icebreaker_hub

# Security
SECRET_KEY=replace-with-a-long-random-secret
JWT_SECRET=replace-with-a-long-random-jwt-secret
JWT_EXPIRES_MINUTES=60

# WebSocket
WS_PING_INTERVAL_SECONDS=20
WS_PING_TIMEOUT_SECONDS=60
MAX_ROOM_PLAYERS=200

# LLM Provider Selection
LLM_PROVIDER=openai

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic (required if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Optional fallback provider behavior
LLM_FALLBACK_ENABLED=true

# Logging and observability
LOG_LEVEL=INFO
ENABLE_STRUCTURED_LOGS=true
